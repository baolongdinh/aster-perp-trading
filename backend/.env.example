# Aster Bot — Environment Variables
# Copy this file to .env and fill in your values. NEVER commit .env.

# === V3 Authentication (Required - API Wallet/Agent Model) ===
# Your main wallet address (user)
ASTER_USER_WALLET=0xYOUR_MAIN_WALLET_ADDRESS_HERE

# Your API wallet address (signer)
ASTER_API_SIGNER=0xYOUR_API_WALLET_ADDRESS_HERE

# Your API wallet private key (NEVER set here - use env var only)
# This is the private key of your API wallet address
ASTER_API_SIGNER_KEY=YOUR_API_WALLET_PRIVATE_KEY_HERE

# === Telegram Alerts (Optional) ===
# Get bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# Get chat ID from @userinfobot or API call
TELEGRAM_CHAT_ID=7373182316
# Set to "false" to disable without removing config
TELEGRAM_ENABLED=true
