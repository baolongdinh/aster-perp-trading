# Aster Bot — Environment Variables
# Copy this file to .env and fill in your values. NEVER commit .env.

# --- Required ---
# Your Aster API Key (from exchange dashboard -> API Management)
ASTER_EXCHANGE_API_KEY=

# Your Aster API Secret (keep this safe, do not share!)
ASTER_API_SECRET=

# --- Optional overrides ---
# Override any config.yaml value. Examples:
# ASTER_BOT_DRY_RUN=false
# ASTER_RISK_DAILY_LOSS_LIMIT_USDT=200
# ASTER_API_PORT=9090
# ASTER_LOG_LEVEL=debug
